---
import Breadcrumb from '@/components/Breadcrumb.astro'
import ProjectCard from '@/components/sections/Projects/ProjectCard.astro'
import { featuredProjects } from '@/data/projects'
---

<div id="projects" class="container-section md:justify-start overflow-hidden">
  <Breadcrumb name="projects" />
  <div class="flex flex-col gap-5 lg:gap-8 max-h-full">
    <h3 class="text-title">
      Featured <span class="text-brand">Projects</span>
    </h3>

    <div class="flex flex-col gap-6 md:pb-20 overflow-y-auto pr-1">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
      <a
        href="/projects"
        class="w-fit rounded-full border border-brand px-5 py-2.5 text-sm font-semibold text-brand transition hover:bg-brand hover:text-brand-dark1 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand"
      >
        View All Projects
      </a>
    </div>
  </div>
</div>

<style></style>
